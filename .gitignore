# Secrets
eurollm/.env

# Virtual environment
eurollm/.venv/

# Python bytecode
**/__pycache__/
*.pyc
*.pyo

# Generated results (regenerate with SLURM jobs)
eurollm/results/
# Figures: ignore flat-dir generated PNGs, keep organized subdirs + report
eurollm/figures/*.png
!eurollm/figures/inglehart_welzel_reference.png
eurollm/figures copy/
eurollm/human_comparison.parquet
eurollm/jsd_matrix.npz
eurollm/summary_stats.parquet

# SQLite database (tracked via git-lfs)
# eurollm/data/survey.db
eurollm/data/survey.db-shm
eurollm/data/survey.db-wal

# Gemini alignment cache
eurollm/.alignment_cache/

# CSV exports (regenerate from survey.db)
eurollm/data/exports/

# SLURM logs
eurollm/logs/

# User-downloaded data (requires GESIS registration)
eurollm/human_data/data/

# Debug artifacts
eurollm/questionnaires/*.raw_response.txt

# gemma-sae: generated data (rebuild with `make populate-full`)
gemma-sae/data/culture.db
gemma-sae/data/culture.db-shm
gemma-sae/data/culture.db-wal
gemma-sae/data/batch_requests.jsonl
gemma-sae/data/sae_cache/
gemma-sae/data/probes/
gemma-sae/logs/

# gemma-sae: virtual environment
gemma-sae/.venv/

# Jupyter
.ipynb_checkpoints/

# OS / IDE
.DS_Store
*.swp
*.swo
.vscode/
.idea/
